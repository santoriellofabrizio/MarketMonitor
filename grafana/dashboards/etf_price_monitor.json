{
  "__inputs": [
    {
      "name": "DS_REDIS",
      "label": "Redis-TimeSeries",
      "description": "Redis Stack datasource su porta 6380",
      "type": "datasource",
      "pluginId": "redis-datasource",
      "pluginName": "Redis"
    },
    {
      "name": "DS_SQLITE",
      "label": "anagraphic_db",
      "description": "SQLite anagraphic database (VW_ISIN_TICKER, beta_large_cluster)",
      "type": "datasource",
      "pluginId": "frser-sqlite-datasource",
      "pluginName": "SQLite"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "redis-datasource",
      "name": "Redis",
      "version": "2.0.0"
    },
    {
      "type": "datasource",
      "id": "frser-sqlite-datasource",
      "name": "SQLite",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    }
  ],
  "uid": "etf-price-monitor-v2",
  "title": "ETF Price Monitor",
  "description": "Monitoring live di mid, prezzi teorici, misalignment e beta per ETF equity",
  "tags": ["etf", "equities", "redis-ts", "live"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "3h", "6h", "12h", "24h"]
  },
  "templating": {
    "list": [
      {
        "name": "isin",
        "type": "query",
        "label": "ETF",
        "datasource": {
          "type": "frser-sqlite-datasource",
          "uid": "${DS_SQLITE}"
        },
        "query": "SELECT TICKER as __text, ISIN as __value FROM VW_ISIN_TICKER ORDER BY TICKER",
        "sort": 0,
        "multi": false,
        "includeAll": false,
        "refresh": 1,
        "hide": 0,
        "options": [],
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Valori Correnti — ${isin:text}",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Mid Price (EUR)",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 6 },
      "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "decimals": 5,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
          "command": "ts.get",
          "keyName": "ts:${isin}:mid",
          "legend": "Mid"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Misalignment — Index Cluster",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 6 },
      "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null    },
              { "color": "orange", "value": -0.005  },
              { "color": "green",  "value": -0.002  },
              { "color": "green",  "value":  0.002  },
              { "color": "orange", "value":  0.005  },
              { "color": "red",    "value":  0.01   }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
          "command": "ts.get",
          "keyName": "ts:${isin}:live_idx_mis",
          "legend": "Index Mis"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Misalignment — Cluster",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 6 },
      "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null    },
              { "color": "orange", "value": -0.005  },
              { "color": "green",  "value": -0.002  },
              { "color": "green",  "value":  0.002  },
              { "color": "orange", "value":  0.005  },
              { "color": "red",    "value":  0.01   }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
          "command": "ts.get",
          "keyName": "ts:${isin}:live_clust_mis",
          "legend": "Cluster Mis"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Misalignment — Intraday",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 6 },
      "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null    },
              { "color": "orange", "value": -0.005  },
              { "color": "green",  "value": -0.002  },
              { "color": "green",  "value":  0.002  },
              { "color": "orange", "value":  0.005  },
              { "color": "red",    "value":  0.01   }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
          "command": "ts.get",
          "keyName": "ts:${isin}:intraday_mis",
          "legend": "Intraday Mis"
        }
      ]
    },
    {
      "id": 6,
      "type": "row",
      "title": "Prezzi nel Tempo",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Mid vs Prezzi Teorici — ${isin:text}",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 10 },
      "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 5,
          "custom": {
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 5,
            "pointSize": 3,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Mid" },
            "properties": [
              { "id": "custom.lineWidth", "value": 3 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#1F60C4" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Index Cluster" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#E0B400" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Cluster" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#37872D" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Intraday" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#C4162A" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
          "command": "ts.range",
          "keyName": "ts:${isin}:mid",
          "legend": "Mid"
        },
        {
          "refId": "B",
          "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
          "command": "ts.range",
          "keyName": "ts:${isin}:live_idx",
          "legend": "Index Cluster"
        },
        {
          "refId": "C",
          "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
          "command": "ts.range",
          "keyName": "ts:${isin}:live_clust",
          "legend": "Cluster"
        },
        {
          "refId": "D",
          "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
          "command": "ts.range",
          "keyName": "ts:${isin}:intraday",
          "legend": "Intraday"
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "Misalignment nel Tempo",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Misalignment % — ${isin:text}",
      "description": "Scarto % del prezzo teorico rispetto al mid. Verde = allineato (±20bps), Arancione = ±50bps, Rosso = >100bps",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 10 },
      "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min", "max", "mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "custom": {
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 3,
            "showPoints": "never",
            "spanNulls": false,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null   },
              { "color": "orange", "value": -0.005 },
              { "color": "green",  "value": -0.002 },
              { "color": "green",  "value":  0.002 },
              { "color": "orange", "value":  0.005 },
              { "color": "red",    "value":  0.01  }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Index Mis" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#E0B400" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Cluster Mis" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#37872D" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Intraday Mis" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#C4162A" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
          "command": "ts.range",
          "keyName": "ts:${isin}:live_idx_mis",
          "legend": "Index Mis"
        },
        {
          "refId": "B",
          "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
          "command": "ts.range",
          "keyName": "ts:${isin}:live_clust_mis",
          "legend": "Cluster Mis"
        },
        {
          "refId": "C",
          "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
          "command": "ts.range",
          "keyName": "ts:${isin}:intraday_mis",
          "legend": "Intraday Mis"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Beta — ${isin:text}",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 11,
      "type": "table",
      "title": "Beta drivers (ultimo aggiornamento)",
      "description": "Drivers con beta ≠ 0 per l'ISIN selezionato, snapshot più recente",
      "gridPos": { "x": 0, "y": 30, "w": 10, "h": 12 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Beta" }],
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Beta" },
            "properties": [
              { "id": "unit", "value": "none" },
              { "id": "decimals", "value": 4 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red",         "value": null   },
                    { "color": "light-red",   "value": -0.5   },
                    { "color": "light-green", "value": -0.1   },
                    { "color": "green",       "value":  0.1   },
                    { "color": "light-green", "value":  0.5   },
                    { "color": "red",         "value":  1.0   }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Driver" },
            "properties": [
              { "id": "custom.width", "value": 180 }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
          "rawQueryText": "SELECT COALESCE(t.TICKER, b.DRIVER) as \"Driver\", ROUND(b.BETA, 4) as \"Beta\" FROM beta_large_cluster b LEFT JOIN VW_ISIN_TICKER t ON b.DRIVER = t.ISIN WHERE b.ISIN = '${isin}' AND ABS(b.BETA) > 0.0001 AND b.DATETIME = (SELECT MAX(DATETIME) FROM beta_large_cluster WHERE ISIN = '${isin}') ORDER BY ABS(b.BETA) DESC",
          "queryType": "table",
          "timeColumns": []
        }
      ]
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Beta per driver — ${isin:text}",
      "description": "Magnitudine e segno dei beta (snapshot più recente)",
      "gridPos": { "x": 10, "y": 30, "w": 14, "h": 12 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10,
        "namePlacement": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 4,
          "min": -1,
          "max": 1,
          "color": { "mode": "continuous-BlPu" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null  },
              { "color": "green", "value":  0.0  }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
          "rawQueryText": "SELECT COALESCE(t.TICKER, b.DRIVER) as \"metric\", ROUND(b.BETA, 4) as \"value\" FROM beta_large_cluster b LEFT JOIN VW_ISIN_TICKER t ON b.DRIVER = t.ISIN WHERE b.ISIN = '${isin}' AND ABS(b.BETA) > 0.0001 AND b.DATETIME = (SELECT MAX(DATETIME) FROM beta_large_cluster WHERE ISIN = '${isin}') ORDER BY b.BETA DESC",
          "queryType": "table",
          "timeColumns": []
        }
      ]
    },
    {
      "id": 13,
      "type": "row",
      "title": "Overview tutti gli ISIN",
      "collapsed": true,
      "gridPos": { "x": 0, "y": 42, "w": 24, "h": 1 },
      "panels": [
        {
          "id": 14,
          "type": "table",
          "title": "Misalignment corrente — tutti gli ISIN (Cluster)",
          "gridPos": { "x": 0, "y": 43, "w": 24, "h": 12 },
          "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
          "options": {
            "footer": { "show": false },
            "showHeader": true,
            "sortBy": [{ "desc": true, "displayName": "Valore" }]
          },
          "fieldConfig": {
            "defaults": {
              "unit": "percentunit",
              "decimals": 4,
              "custom": {
                "align": "auto",
                "cellOptions": { "type": "color-background" }
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "red",    "value": null   },
                  { "color": "orange", "value": -0.005 },
                  { "color": "green",  "value": -0.002 },
                  { "color": "green",  "value":  0.002 },
                  { "color": "orange", "value":  0.005 },
                  { "color": "red",    "value":  0.01  }
                ]
              }
            },
            "overrides": []
          },
          "targets": [
            {
              "refId": "A",
              "datasource": { "type": "redis-datasource", "uid": "${DS_REDIS}" },
              "command": "ts.mrange",
              "filter": "field=live_clust_mis",
              "legend": "Valore"
            }
          ]
        }
      ]
    }
  ]
}
